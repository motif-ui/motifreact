{
  "name": "@motif-ui/react",
  "version": "0.4.2",
  "description": "A React UI library created by public sector developers",
  "author": "MOTIF UI | Turksat e-Government Application Development",
  "homepage": "https://github.com/motif-ui/motifreact#readme",
  "bugs": {
    "url": "https://github.com/motif-ui/motifreact/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/motif-ui/motifreact.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "next build",
    "build:lib": "rollup -c",
    "build:storybook": "storybook build --webpack-stats-json",
    "build:theme": "node src/scripts/buildTheme",
    "build:theme-default": "npm run build:theme src/lib/styles/tokens/design-tokens.tokens.json default-theme src/lib/styles/themes",
    "build:tokens": "node src/scripts/buildToken",
    "check:scss": "npx stylelint '**/*.scss'",
    "check:type": "tsc --noemit",
    "dev": "next dev --webpack",
    "lint": "eslint",
    "lint:staged": "eslint --cache",
    "maintenance-check": "npm run lint && npm run check:type && npm run test:ci && npm run build:lib && npm run build:theme-default && concurrently -n 'NEXT,STORY' -c 'cyan,magenta' 'npm run dev' 'npm run storybook'",
    "prepare": "husky",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "test": "jest --watch",
    "test:ci": "jest --ci",
    "test:update": "npm run test:ci -- -u"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.2.1",
    "@eslint/js": "^9.39.4",
    "@rollup-extras/plugin-copy": "^2.1.0",
    "@rollup/plugin-alias": "6.0.0",
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@storybook/addon-docs": "10.4.2",
    "@storybook/addon-links": "10.4.2",
    "@storybook/nextjs": "10.4.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "30.0.0",
    "@types/node": "^25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "browserslist": "^4.28.0",
    "chromatic": "17.3.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-compat": "7.0.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "16.4.0",
    "next": "^16.2.4",
    "postcss-url": "10.1.4",
    "prettier": "3.8.3",
    "rollup": "^4.60.2",
    "rollup-plugin-delete": "^3.0.2",
    "rollup-plugin-dts": "6.4.1",
    "rollup-plugin-jsx-remove-attributes": "^3.1.2",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-styler": "^2.0.0",
    "sass": "1.100.0",
    "storybook": "10.4.2",
    "style-dictionary": "5.4.3",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.0",
    "use-deep-compare-effect": "^1.8.1"
  },
  "peerDependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.es.js",
      "require": "./dist/hooks.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.es.js",
      "require": "./dist/types.cjs"
    },
    "./themes/*": "./dist/themes/*",
    "./*": "./dist/*"
  },
  "keywords": [
    "motif",
    "react",
    "ui",
    "library",
    "component",
    "public",
    "sector",
    "design",
    "token",
    "turksat",
    "e-devlet",
    "turkiye",
    "gov"
  ]
}
